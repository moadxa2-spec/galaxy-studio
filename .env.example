# Galaxy Studio — Environment Variables
# Copy this file to .env and fill in your values

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Server
PORT=8000

# CORS — set to your Hostinger domain in production
# Example: https://galaxystudio.yourdomain.com
# Use * only in development
ALLOWED_ORIGIN=*

# Environment
NODE_ENV=production

# Optional: set to ./dist if you add a Vite build step
# STATIC_DIR=./dist
